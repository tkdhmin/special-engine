{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ssdbench scenario",
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "version", "workload", "runtime", "engine"],
    "properties": {
        "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "scenario id, lowercase snake_case"
        },
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "description": {
            "type": "string"
        },
        "workload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern", "block_size", "io_depth", "num_jobs"],
            "properties": {
                "pattern": {
                    "type": "string",
                    "enum": ["read", "write", "randread", "randwrite", "rw", "randrw"]
                },
                "block_size": {
                    "type": "string",
                    "pattern": "^[0-9]+[kKmM]?$"
                },
                "io_depth": {
                    "type": "integer",
                    "minimum": 1
                },
                "num_jobs": {
                    "type": "integer",
                    "minimum": 1
                },
                "rw_mix_read": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "read percentage for rw and randrw patterns"
                }
            }
        },
        "runtime": {
            "type": "object",
            "additionalProperties": false,
            "required": ["duration_sec"],
            "properties": {
                "duration_sec": {
                    "type": "integer",
                    "minimum": 1
                },
                "ramp_sec": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                }
            }
        },
        "engine": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "direct"],
            "properties": {
                "name": {
                    "type": "string",
                    "enum": ["io_uring", "libaio", "psync", "sync"]
                },
                "direct": {
                    "type": "boolean"
                }
            }
        }
    }
}
